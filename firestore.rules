rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    // "Admin" is the legacy name — this role is now called Backstage Manager.
    // Updated 2026-03-01 by Claude.
    // Claude: 2026-03-03 — hardcoded email. When adding admins, update BOTH this function
    // AND the ADMIN_EMAILS array in aa-firebase.js (see modular/aa-firebase.js line 28).
    function isBackstageManager() {
      return isSignedIn() && request.auth.token.email == 'brinckmyster@gmail.com';
    }

    // ── Users ────────────────────────────────────────────────────
    // Any signed-in user reads (needed for lookupByEmail, getAllStudents,
    // support network scanning in aa-mirror). Owner or admin writes.
    // Claude: 2026-03-03 — intentionally kept open for functional reasons (name
    // lookups, invite redemption, network scanning). User docs contain role +
    // display name but NOT health data — health data lives in scoped collections
    // below. Tighter scoping here requires denormalizing the network graph and
    // is deferred to a future compliance sprint.
    // Special narrow update rules allow invite redemption and isSupporter flag.
    // Updated 2026-02-26 by Claude — invite redemption permissions fix.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid) || isBackstageManager();

      // Invite redemption: a signed-in user may add ONLY their own uid key to
      // another user's supportNetwork, and only with a valid tier value.
      // The invite code is the real security gate; this rule limits raw API abuse
      // by restricting writes to self-keyed entries with valid tiers only.
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['supportNetwork'])
        && request.resource.data.supportNetwork.diff(
             resource.data.get('supportNetwork', {})
           ).affectedKeys().hasOnly([request.auth.uid])
        && request.resource.data.supportNetwork[request.auth.uid]
             in ['family', 'support', 'nearby-help', 'network-lead'];

      // isSupporter flag: any signed-in user may set/clear ONLY the isSupporter
      // field on another user's doc (set by setNetworkMember when adding to network).
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['isSupporter']);

      // Network Lead edit: a network-lead member may update only the studentProfile
      // field on a student's doc (conditions, notes, customizations for that student).
      // Verified by checking the student's own supportNetwork map.
      // Added 2026-02-26 by Claude.
      allow update: if isSignedIn()
        && resource.data.role == 'student'
        && resource.data.get('supportNetwork', {})[request.auth.uid] == 'network-lead'
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['studentProfile']);

      // Network Lead network management: a network-lead may add, remove, or change
      // the roles of members in their student's supportNetwork map (and the paired
      // isSupporter flag that setNetworkMember/removeNetworkMember writes).
      // Updated 2026-02-28 by Claude.
      allow update: if isSignedIn()
        && resource.data.role == 'student'
        && resource.data.get('supportNetwork', {})[request.auth.uid] == 'network-lead'
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['supportNetwork', 'isSupporter']);
    }

    // ── Pending pre-registrations — admin only ───────────────────
    // Non-admins intentionally get PERMISSION_DENIED here on first sign-in;
    // aa-firebase.js catches the error and falls through to default role.
    match /pendingUsers/{email} {
      allow read, write: if isBackstageManager();
    }

    // ── Nope mode ────────────────────────────────────────────────
    // Claude: 2026-03-03 compliance fix — scoped to owner + network + admin.
    // Crisis mode status is sensitive health data; not readable by all users.
    match /nope/{uid} {
      allow read: if isOwner(uid) || isNetworkMember(uid) || isBackstageManager();
      allow write: if isOwner(uid) || isNetworkLead(uid);

      match /logs/{logId} {
        allow read: if isOwner(uid) || isNetworkMember(uid) || isBackstageManager();
        allow create: if isOwner(uid) || isNetworkLead(uid);
        allow update, delete: if false;
      }
    }

    // ── Flower quiz ───────────────────────────────────────────────
    // Claude: 2026-03-03 compliance fix — personal data, owner + admin only.
    match /flowerQuiz/{uid} {
      allow read: if isOwner(uid) || isNetworkLead(uid) || isBackstageManager();
      allow write: if isOwner(uid);
    }

    // ── Emergency Contacts ───────────────────────────────────────
    // Private per-student contact list. Readable by the student,
    // their network-lead (network admin), and Backstage Manager (platform admin).
    // Added 2026-02-28 by Claude.
    function isNetworkLead(studentUid) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(studentUid))
          .data.get('supportNetwork', {})[request.auth.uid] == 'network-lead';
    }
    // Any member of the student's support network (any role value = string).
    // Added 2026-03-01 by Claude — used by networkChat rules.
    function isNetworkMember(studentUid) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(studentUid))
          .data.get('supportNetwork', {})[request.auth.uid] is string;
    }
    match /emergencyContacts/{uid} {
      allow read:  if isOwner(uid) || isNetworkLead(uid) || isBackstageManager();
      // Student can self-manage; network-lead (network admin) and Backstage Manager
      // (platform admin) can also write.
      // Updated 2026-03-01 by Claude: reverted unauthorized isNetworkMember change.
      allow write: if isOwner(uid) || isNetworkLead(uid) || isBackstageManager();
    }

    // ── Check-ins ────────────────────────────────────────────────
    // Claude: 2026-03-03 compliance fix — sensitive health data (mental/physical/mood).
    // Scoped to owner + assigned network members + admin only.
    match /checkins/{uid} {
      allow read: if isOwner(uid) || isNetworkMember(uid) || isBackstageManager();
      allow write: if isOwner(uid);

      match /days/{dateKey} {
        allow read: if isOwner(uid) || isNetworkMember(uid) || isBackstageManager();
        allow write: if isOwner(uid);
      }
    }

    // ── Meal plans (base plan) ───────────────────────────────────
    // Claude: 2026-03-03 compliance fix — dietary/health data, network-scoped.
    match /mealPlans/{uid} {
      allow read: if isOwner(uid) || isNetworkMember(uid) || isBackstageManager();
      allow write: if isOwner(uid) || isNetworkLead(uid) || isBackstageManager();
    }

    // ── Meal logs (daily actuals) ────────────────────────────────
    // Claude: 2026-03-03 compliance fix — network-scoped.
    match /mealLogs/{uid} {
      allow read: if isOwner(uid) || isNetworkMember(uid) || isBackstageManager();
      allow write: if isOwner(uid) || isNetworkLead(uid) || isBackstageManager();

      match /days/{dateKey} {
        allow read: if isOwner(uid) || isNetworkMember(uid) || isBackstageManager();
        allow write: if isOwner(uid) || isNetworkLead(uid) || isBackstageManager();
      }
    }

    // ── SpoonPal ─────────────────────────────────────────────────
    // Claude: 2026-03-03 compliance fix — SpoonPal is owner-private (Bruise only).
    // No network read — this is a personal tool, not shared with support network.
    match /spoonPal/{uid} {
      allow read: if isOwner(uid) || isBackstageManager();
      allow write: if isOwner(uid) || isBackstageManager();

      // Claude: 2026-03-08 — daily archive subcollection for rolloverDay().
      // Archive: rule was missing; rolloverDay() writes to spoonPal/{uid}/days/{dateKey}
      // but Firestore denied it silently (caught by .catch on the client).
      match /days/{dateKey} {
        allow read, write: if isOwner(uid) || isBackstageManager();
      }
    }

    // ── Spoon Plan ───────────────────────────────────────────────
    // Claude: 2026-03-03 compliance fix — network-scoped (support can see day plan).
    match /spoonPlans/{uid} {
      allow read: if isOwner(uid) || isNetworkMember(uid) || isBackstageManager();
      allow write: if isOwner(uid) || isNetworkLead(uid) || isBackstageManager();
    }

    // ── Recovery Journal ─────────────────────────────────────────
    // Auto-saved journal entries from recovery-mode.html.
    // Doc ID is a random session key (not uid); uid is stored inside the doc.
    // Owner reads/writes their own entries; admin can read all.
    // Added 2026-02-28 by Claude.
    match /recoveryJournal/{sessionId} {
      allow read: if isSignedIn()
        && (resource.data.uid == request.auth.uid || isNetworkLead(resource.data.uid) || isBackstageManager());
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn()
        && (resource.data.uid == request.auth.uid || isBackstageManager());
    }

    // ── Invites (Amanda sudo — student-generated invite codes) ───
    // Added 2026-02-26 by Claude
    //
    // Document ID = the invite code itself (e.g. "XK9P2M")
    // Schema: { code, studentUid, studentName, role, createdAt,
    //           expiresAt, used, usedAt, usedBy }
    //
    // CREATE:  only the student who owns the invite (studentUid == caller)
    // READ:    any signed-in user (they need the code to find it — security
    //          through obscurity is fine here; codes are short-lived + single-use)
    // LIST:    student can query their own invites (studentUid == caller)
    // REDEEM:  any signed-in user can mark used=true + set usedBy/usedAt
    //          (but cannot change studentUid, role, or code)
    // REVOKE:  student can delete their own unused invite
    // ADMIN:   platform admin can read/delete any invite
    match /invites/{code} {
      // Anyone signed-in can read a specific invite doc (needed to redeem)
      allow read: if isSignedIn();

      // Student creates invite for their own uid; network lead creates for their student
      allow create: if isSignedIn()
        && (request.resource.data.studentUid == request.auth.uid
            || isNetworkLead(request.resource.data.studentUid))
        && request.resource.data.used == false
        && request.resource.data.role in ['family','support','nearby-help','network-lead'];

      // Redemption: any signed-in user can flip used→true on an unused invite.
      // They cannot change studentUid, role, code, createdAt, or expiresAt.
      allow update: if isSignedIn()
        && resource.data.used == false
        && request.resource.data.used == true
        && request.resource.data.usedBy == request.auth.uid
        && request.resource.data.studentUid == resource.data.studentUid
        && request.resource.data.role == resource.data.role
        && request.resource.data.code == resource.data.code;

      // Student or network lead revokes unused invite; admin can delete any
      allow delete: if isBackstageManager()
        || (isSignedIn()
            && resource.data.studentUid == request.auth.uid
            && resource.data.used == false)
        || (isSignedIn()
            && isNetworkLead(resource.data.studentUid)
            && resource.data.used == false);
    }

    // ── Network Chat ─────────────────────────────────────────────
    // Group thread and supporter-to-supporter DMs scoped to a student's network.
    // Students are not in any supportNetwork so isNetworkMember() naturally
    // excludes them — no explicit student check needed.
    // Added 2026-03-01 by Claude.
    match /networkChat/{studentUid} {
      // Root meta doc (lastGroupAt, lastGroupMsg)
      allow read, write: if isNetworkMember(studentUid) || isBackstageManager();

      // Group thread messages
      match /group/{msgId} {
        allow read: if isNetworkMember(studentUid) || isBackstageManager();
        allow create: if (isNetworkMember(studentUid) || isBackstageManager())
          && request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if false;
      }

      // DM threads between network members
      match /dms/{threadId} {
        // Thread meta doc (participants, lastAt, lastMsg)
        allow read, write: if isNetworkMember(studentUid) || isBackstageManager();

        match /msgs/{msgId} {
          allow read: if isNetworkMember(studentUid) || isBackstageManager();
          allow create: if (isNetworkMember(studentUid) || isBackstageManager())
            && request.resource.data.senderUid == request.auth.uid;
          allow update, delete: if false;
        }
      }
    }

    // ── Messages ─────────────────────────────────────────────────
    // Thread doc — participants array controls who can access.
    // watchThreads() uses array-contains query which is consistent
    // with the read rule, so Firestore allows the query.
    match /messages/{threadId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants;
      allow delete: if false;

      // Individual messages
      // !exists() handles the race condition on first send: the thread doc
      // set() and msgs add() happen back-to-back; the server may not have
      // committed the thread doc yet when the msgs rule fires on first message.
      match /msgs/{msgId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/messages/$(threadId)).data.participants;
        allow create: if isSignedIn()
          && request.auth.uid == request.resource.data.senderUid
          && (
            !exists(/databases/$(database)/documents/messages/$(threadId))
            || request.auth.uid in get(/databases/$(database)/documents/messages/$(threadId)).data.participants
          );
        allow update, delete: if false;
      }
    }

    // ── Notifications (per-user inbox) ────────────────────────────
    // Stored under /users/{uid}/notifications/{notifId}
    // Compliance: notify students when someone joins their network (FERPA audit trail)
    // Added 2026-03-03 by Claude
    match /users/{uid}/notifications/{notifId} {
      // Claude: owner + backstage manager can read/delete notifications
      allow read, delete: if isOwner(uid) || isBackstageManager();
      // Claude: any signed-in user can write a notification to any user
      allow create: if isSignedIn();
    }

    // ── Audit Log — student-scoped, append-only ───────────────────
    // Path: /auditLog/{targetUid}/entries/{logId}
    // Students can read their own audit trail (FERPA right to know who accessed records).
    // Network members can also read (support team transparency).
    // Only the system (any signed-in user) can create. Nobody can update or delete.
    // Added 2026-03-03 by Claude — restructured 2026-03-03 for student visibility.
    match /auditLog/{targetUid} {
      allow read: if isOwner(targetUid) || isNetworkMember(targetUid) || isBackstageManager();
      allow write: if false; // no direct writes to the container doc

      match /entries/{logId} {
        allow read: if isOwner(targetUid) || isNetworkMember(targetUid) || isBackstageManager();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    // ── Audio Notes — personal recordings with transcripts ────────
    // Claude: 2026-03-03 — owner + network members + admin can read (mirror support).
    // Only owner can write (recording is personal).
    match /audioNotes/{uid} {
      allow read: if isOwner(uid) || isNetworkMember(uid) || isBackstageManager();
      allow write: if isOwner(uid);

      match /notes/{noteId} {
        allow read: if isOwner(uid) || isNetworkMember(uid) || isBackstageManager();
        allow create, update: if isOwner(uid);
        allow delete: if isOwner(uid) || isBackstageManager();
      }
    }

    // ── Deletion requests — user submits, admin processes ─────────
    // Claude: FERPA/HIPAA right to erasure — 2026-03-03
    match /deletionRequests/{reqId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if isBackstageManager();
    }

    // ── Message drafts — unsent compose text, per user per thread ──
    // Claude: 2026-03-07 — added missing rule (collection was defaulting to deny).
    // Path: messageDrafts/{uid}_{threadId}
    // Draft content is low-sensitivity. Any signed-in user may read/write.
    // Future: tighten by adding uid field to draft docs and checking resource.data.uid.
    match /messageDrafts/{draftId} {
      allow read, write: if isSignedIn();
    }

  }
}
